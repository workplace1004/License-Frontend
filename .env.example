# License API. Local: license-server on 5050. Production: your deployed license API.
LICENSE_API_URL=http://127.0.0.1:5050

# Optional: Vite dev proxies /issuer-api to this URL. Default = LICENSE_API_URL (5050).
# Use http://127.0.0.1:5180 only with `npm run dev:with-proxy` (runs server.mjs + vite).
# ISSUER_DEV_PROXY_TARGET=http://127.0.0.1:5180

# To hit production from the issuer UI (copy to `.env` / set in deploy). CORS on the API must allow this origin.
# VITE_LICENSE_API_URL=https://b2b-nest-backend-production.up.railway.app

# Or proxy local issuer dev to Railway instead of localhost:5050:
# LICENSE_API_URL=https://b2b-nest-backend-production.up.railway.app

# Optional; forwarded by server.mjs as Bearer when using dev:with-proxy. Must match license-server LICENSE_ADMIN_SECRET.
LICENSE_ADMIN_SECRET=

# Port for server.mjs (used with dev:with-proxy).
ISSUER_SERVER_PORT=5180

# Address autocomplete: dev uses Vite proxy /issuer-geocode → Nominatim (no key).
# Production (e.g. Vercel): set to /api/address-suggest if you deploy api/address-suggest.js, or any URL that returns Nominatim-style JSON [{ display_name, ... }, ...].
# VITE_ADDRESS_SUGGEST_URL=/api/address-suggest
